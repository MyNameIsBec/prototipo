<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      spacing="0" style="-fx-background-color: #f5f5f5;">

    <!-- Sidebar -->
    <VBox spacing="0" prefWidth="240" style="-fx-background-color: #1e293b; -fx-padding: 0;">
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 20 16;">
            <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                <image><Image url="@/images/logo.png" backgroundLoading="true"/></image>
            </ImageView>
            <Label text="Portfolio AFAM" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" />
        </HBox>
        <Label text="Interfacce sempre disponibili" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8; -fx-padding: 0 16 12 16; -fx-underline: true;" />
        <VBox spacing="0">
            <Button onAction="#handleVaiAContenuti" style="-fx-background-color: transparent; -fx-padding: 12 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-background-radius: 0;">
                <graphic>
                    <HBox spacing="11" alignment="CENTER_LEFT">
                        <Label text="I miei contenuti" style="-fx-font-size: 14px; -fx-text-fill: #cbd5e1;" />
                    </HBox>
                </graphic>
            </Button>
            <Button onAction="#handleVaiACondivisioni" style="-fx-background-color: transparent; -fx-padding: 12 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-background-radius: 0;">
                <graphic>
                    <HBox spacing="11" alignment="CENTER_LEFT">
                        <Label text="Condivisioni" style="-fx-font-size: 14px; -fx-text-fill: #cbd5e1;" />
                    </HBox>
                </graphic>
            </Button>
            <VBox prefHeight="1" style="-fx-background-color: #334155;" maxWidth="200">
                <padding><Insets left="16" right="16"/></padding>
            </VBox>
            <Button onAction="#handleLogout" style="-fx-background-color: transparent; -fx-padding: 12 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-background-radius: 0;">
                <graphic>
                    <HBox spacing="11" alignment="CENTER_LEFT">
                        <Label text="Logout" style="-fx-font-size: 14px; -fx-text-fill: #ef4444;" />
                    </HBox>
                </graphic>
            </Button>
        </VBox>
    </VBox>

    <!-- Main content -->
    <VBox spacing="0" HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f5f5;">
        <!-- Topbar -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 16 26; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <Label text="Il mio profilo" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Content -->
        <HBox spacing="26" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" style="-fx-background-color: #f5f5f5;">
            <padding><Insets top="22" right="26" bottom="22" left="26" /></padding>

            <!-- Avatar section -->
            <VBox alignment="TOP_CENTER" spacing="10" prefWidth="120">
                <StackPane maxWidth="90" maxHeight="90">
                    <ImageView fx:id="immagineProfilo" fitWidth="80" fitHeight="80" preserveRatio="true"
                               style="-fx-cursor: hand;" onMouseClicked="#handleModificaImmagine"
                               pickOnBounds="true" />
                    <Label text="cambia" style="-fx-font-size: 10px; -fx-background-color: #6366f1; -fx-background-radius: 8; -fx-padding: 2 6; -fx-text-fill: white;" StackPane.alignment="BOTTOM_RIGHT">
                        <StackPane.margin><Insets right="-4" bottom="-4"/></StackPane.margin>
                    </Label>
                </StackPane>
            </VBox>

            <!-- Profile form -->
            <VBox spacing="0" HBox.hgrow="ALWAYS">
                <HBox spacing="10">
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="Nome e Cognome" style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-weight: bold;" />
                        <Label fx:id="nomeCognomeLabel" text="" style="-fx-font-size: 14px; -fx-background-color: white; -fx-padding: 10 14; -fx-min-height: 44px; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="12" /></padding>
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="Email" style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-weight: bold;" />
                        <Label fx:id="emailLabel" text="" style="-fx-font-size: 14px; -fx-background-color: white; -fx-padding: 10 14; -fx-min-height: 44px; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                    <Button text="Modifica email" onAction="#handleModificaEmail" style="-fx-font-size: 12px; -fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-border-color: #6366f1; -fx-border-radius: 4; -fx-padding: 6 12;" />
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="12" /></padding>
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="Telefono" style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-weight: bold;" />
                        <Label fx:id="telefonoLabel" text="" style="-fx-font-size: 14px; -fx-background-color: white; -fx-padding: 10 14; -fx-min-height: 44px; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                    <Button text="Modifica telefono" onAction="#handleModificaTelefono" style="-fx-font-size: 12px; -fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-border-color: #6366f1; -fx-border-radius: 4; -fx-padding: 6 12;" />
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="12" /></padding>
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="Codice Fiscale" style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-weight: bold;" />
                        <Label fx:id="cfDettaglioLabel" text="" style="-fx-font-size: 14px; -fx-background-color: white; -fx-padding: 10 14; -fx-min-height: 44px; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="12" /></padding>
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="Data di nascita" style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-weight: bold;" />
                        <Label fx:id="nascitaLabel" text="" style="-fx-font-size: 14px; -fx-background-color: white; -fx-padding: 10 14; -fx-min-height: 44px; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="12" /></padding>
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label text="Dati accademici" style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-weight: bold;" />
                        <Label fx:id="datiAccademiciLabel" text="" wrapText="true" style="-fx-font-size: 14px; -fx-background-color: white; -fx-padding: 10 14; -fx-min-height: 44px; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                    <Button text="Modifica dati accademici" onAction="#handleModificaDatiAccademici" style="-fx-font-size: 12px; -fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-border-color: #6366f1; -fx-border-radius: 4; -fx-padding: 6 12;" />
                </HBox>

                <!-- Action buttons -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <padding><Insets top="16" /></padding>
                    <Button text="Modifica password" onAction="#handleModificaPassword" style="-fx-font-size: 12px; -fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-border-color: #6366f1; -fx-border-radius: 4; -fx-padding: 6 12;" />
                    <Button text="Modifica 2FA" onAction="#handleModifica2FA" style="-fx-font-size: 12px; -fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-border-color: #6366f1; -fx-border-radius: 4; -fx-padding: 6 12;" />
                    <Button text="Modifica visibilità" onAction="#handleModificaVisibilita" style="-fx-font-size: 12px; -fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-border-color: #6366f1; -fx-border-radius: 4; -fx-padding: 6 12;" />
                    <Button text="Elimina account" onAction="#handleEliminaAccount" style="-fx-font-size: 12px; -fx-background-color: #ef4444; -fx-text-fill: white; -fx-border-radius: 4; -fx-padding: 6 12;" />
                </HBox>
            </VBox>
        </HBox>

        <!-- GDPR note -->
        <VBox style="-fx-padding: 8 26 12 26;">
            <Label text="L'eliminazione dell'account è reversibile entro 14 giorni; allo scadere i dati saranno cancellati definitivamente (GDPR art. 17)." wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8; -fx-font-style: italic;" />
        </VBox>
    </VBox>
</HBox>
