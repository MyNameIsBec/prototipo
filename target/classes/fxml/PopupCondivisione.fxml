<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER" spacing="20" style="-fx-padding: 30; -fx-background-color: white; -fx-background-radius: 12;">
    <Label text="Il tuo link di condivisione è pronto" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <TextField fx:id="linkField" editable="false" text="http://localhost:8080/share/AbCd1234EfGh"
               style="-fx-font-size: 13px; -fx-background-color: #f0f0f0; -fx-padding: 10; -fx-background-radius: 6;" prefWidth="400"/>
    <HBox spacing="15" alignment="CENTER">
        <Button text="COPIA LINK" onAction="#handleCopiaLink" prefWidth="150"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="INVIA EMAIL" onAction="#handleInviaEmail" prefWidth="150"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>
