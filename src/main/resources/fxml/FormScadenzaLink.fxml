<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      spacing="0" style="-fx-background-color: #f5f5f5;">
    <VBox spacing="0" prefWidth="240" style="-fx-background-color: #1e293b; -fx-padding: 0;">
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 20 16;">
            <Label text="Portfolio AFAM" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" />
        </HBox>
        <VBox spacing="0">
            <Button onAction="#handleIndietro" style="-fx-background-color: transparent; -fx-padding: 12 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-background-radius: 0;">
                <graphic><HBox spacing="11" alignment="CENTER_LEFT">
                    <Label text="Indietro" style="-fx-font-size: 14px; -fx-text-fill: #cbd5e1;" />
                </HBox></graphic>
            </Button>
        </VBox>
    </VBox>
    <VBox spacing="20" HBox.hgrow="ALWAYS" alignment="TOP_CENTER" style="-fx-background-color: #f5f5f5;">
        <padding><Insets top="40" left="40" right="40" /></padding>
        <Label text="Genera link portfolio" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <VBox spacing="8" maxWidth="400">
            <Label text="Data di scadenza" style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-weight: bold;" />
            <DatePicker fx:id="scadenzaPicker" style="-fx-padding: 8; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6;" maxWidth="400" />
        </VBox>
        <Button text="Genera" onAction="#handleGenera" style="-fx-font-size: 14px; -fx-background-color: #6366f1; -fx-text-fill: white; -fx-border-radius: 4; -fx-padding: 10 24;" />
    </VBox>
</HBox>
