<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      style="-fx-background-color: #f5f5f5;">
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 12 30; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
            <image><Image url="@/images/logo.png" backgroundLoading="true"/></image>
        </ImageView>
        <Label text="Portfolio AFAM" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="VALUTA" onAction="#handleValuta" style="-fx-font-size: 13px; -fx-background-color: #6366f1; -fx-text-fill: white; -fx-border-radius: 4; -fx-padding: 6 16;" />
        <Button text="SEGNALA" onAction="#handleSegnala" style="-fx-font-size: 13px; -fx-background-color: #ef4444; -fx-text-fill: white; -fx-border-radius: 4; -fx-padding: 6 16;" />
    </HBox>
    <HBox VBox.vgrow="ALWAYS" spacing="0">
        <VBox fx:id="sidebar" spacing="5" style="-fx-padding: 12; -fx-background-color: #1e293b; -fx-min-width: 220; -fx-max-width: 220;">
            <Label text="Contenuti" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 5;" />
        </VBox>
        <VBox alignment="CENTER" spacing="16" HBox.hgrow="ALWAYS" style="-fx-padding: 30;">
            <Label text="Seleziona un contenuto dalla sidebar per visualizzarlo" style="-fx-font-size: 16px; -fx-text-fill: #999; -fx-font-style: italic;" />
            <ImageView fx:id="anteprimaImmagine" fitWidth="400" fitHeight="300" preserveRatio="true" visible="false" style="-fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 2);" />
            <Label fx:id="nomeFileLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" visible="false" />
            <Label fx:id="metadatiLabel" style="-fx-font-size: 13px; -fx-text-fill: #777;" visible="false" wrapText="true" />
        </VBox>
    </HBox>
</VBox>
