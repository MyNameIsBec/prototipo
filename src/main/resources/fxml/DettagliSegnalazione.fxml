<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      alignment="TOP_CENTER" style="-fx-background-color: #f5f5f5;">



    <VBox alignment="TOP_CENTER" VBox.vgrow="ALWAYS" maxWidth="800" spacing="16" style="-fx-padding: 20 30 30 30;">
        <Label text="Contenuto segnalato" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

        <VBox spacing="12" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
            <Label fx:id="nomeContenutoLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <Label fx:id="dettagliContenutoLabel" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" />

            <!-- Preview area -->
            <VBox alignment="CENTER" prefHeight="200" maxHeight="300" style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;">
                <Label fx:id="anteprimaLabel" text="Anteprima contenuto" style="-fx-font-size: 14px; -fx-text-fill: #94a3b8;" />
            </VBox>

            <HBox spacing="10">
                <padding><Insets top="8" /></padding>
                <Button text="← Indietro" onAction="#handleIndietro" style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-background-radius: 4; -fx-padding: 8 14; -fx-font-size: 13px; -fx-cursor: hand;" />
                <Button text="ELIMINA" onAction="#handleElimina" style="-fx-font-size: 13px; -fx-background-color: #ef4444; -fx-text-fill: white; -fx-border-radius: 4; -fx-padding: 8 24; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </VBox>
</VBox>
