<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      alignment="TOP_CENTER" style="-fx-background-color: #f5f5f5;">

    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 12 30; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
            <image><Image url="@/images/logo.png" backgroundLoading="true"/></image>
        </ImageView>
        <Label text="Portfolio AFAM" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Label text="← Home" onMouseClicked="#handleIndietro" style="-fx-font-size: 14px; -fx-text-fill: #6366f1; -fx-cursor: hand; -fx-underline: true;" />
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox alignment="TOP_CENTER" spacing="18" style="-fx-padding: 30 60 40 60;">

            <ImageView fitWidth="160" fitHeight="160" preserveRatio="true">
                <image>
                    <Image url="@/images/portfolio logo.png" backgroundLoading="true"/>
                </image>
            </ImageView>

            <Label text="Crea il tuo account" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="I dati anagrafici e accademici saranno verificati tramite OCR della tessera sanitaria. La 2FA verrà attivata automaticamente."
                   style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;" wrapText="true"/>

            <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;">
                <GridPane hgap="20" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14"/>
                        <ColumnConstraints percentWidth="36"/>
                        <ColumnConstraints percentWidth="14"/>
                        <ColumnConstraints percentWidth="36"/>
                    </columnConstraints>

                    <Label text="Nome" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="nomeField" GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

                    <Label text="Cognome" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="cognomeField" GridPane.rowIndex="0" GridPane.columnIndex="3" GridPane.hgrow="ALWAYS"/>

                    <Label text="Data nascita" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="dataNascitaField" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

                    <Label text="Luogo nascita" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="luogoNascitaField" GridPane.rowIndex="1" GridPane.columnIndex="3" GridPane.hgrow="ALWAYS"/>

                    <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

                    <Label text="Codice fiscale" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                    <TextField fx:id="cfField" GridPane.rowIndex="2" GridPane.columnIndex="3" GridPane.hgrow="ALWAYS"/>

                    <Label text="Telefono" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="telefonoField" GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.hgrow="ALWAYS"/>
                </GridPane>

                <Label text="Dati accademici" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                <TextArea fx:id="datiAccademiciArea" prefRowCount="3"
                          promptText="Corso di laurea, anno iscrizione, matricola..." GridPane.hgrow="ALWAYS"/>

                <CheckBox fx:id="gdprCheckBox"
                          text="Acconsento al trattamento dei dati personali ai sensi del GDPR (UE 2016/679)"
                          wrapText="true" style="-fx-font-size: 12px;"/>
            </VBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Indietro" onAction="#handleIndietro" prefWidth="130" prefHeight="40"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 8;"/>
                <Button fx:id="registratiButton" text="REGISTRATI" onAction="#handleRegistrati"
                        prefWidth="180" prefHeight="40"
                        style="-fx-font-size: 16px; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 8;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
